# Copy this file to `.env` and fill in real values.

# --- Server ---
PORT=3000
NODE_ENV=development
# Frontend origin(s). Comma-separated list is supported, e.g.:
#   CLIENT_URL=https://elif1.netlify.app,https://your-custom-domain.com
CLIENT_URL=http://localhost:5173
# Public URL of THIS backend. Required in production for the Google OAuth
# callback to be built correctly. Must match the URI registered in the
# Google Cloud Console under "Authorized redirect URIs".
# Example: SERVER_URL=https://mock-capstone.onrender.com
SERVER_URL=http://localhost:3000

# --- Database (REQUIRED) ---
MONGO_URL=mongodb://127.0.0.1:27017/elif

# --- Auth (REQUIRED) ---
JWT_SECRET=replace-me-with-a-long-random-string

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (optional, used for image uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI Assistant (optional; falls back to rule-based search if unset) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
