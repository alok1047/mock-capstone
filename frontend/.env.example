VITE_API_BASE_URL=http://localhost:3000/api
VITE_GOOGLE_AUTH_URL=http://localhost:3000/api/auth/google
VITE_GOOGLE_OAUTH_REDIRECT=http://localhost:3000/api/auth/google/callback
VITE_AUTH_PROVIDER_GOOGLE=google

# Google Maps JS API key — required for Places autocomplete + map picker.
# In Google Cloud Console, enable: Maps JavaScript API, Places API (New), Geocoding API.
# Restrict the key by HTTP referrer to your domains (e.g. http://localhost:5173/*).
VITE_GOOGLE_MAPS_API_KEY=

# Required for AdvancedMarkerElement. Use DEMO_MAP_ID for local dev (shows
# a small watermark). For production, create a Map ID at:
# https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
